      "label": "Newsletter headline (second line, italic)",
      "default": "the workshop floor."
    },
    {
      "type": "richtext",
      "id": "newsletter_body",
      "label": "Newsletter body",
      "default": "<p>Production updates, edition openings, and notes from the studio floor.</p>"
