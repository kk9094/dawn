{%- liquid
  assign hero_image_url = ''
  if section.settings.hero_image != blank
    assign hero_image_url = section.settings.hero_image | image_url: width: 2754
  endif
-%}

<section
  class="vf-hero-composite"
  id="vf-hero-composite-{{ section.id }}"
  {% if hero_image_url != blank %}style="background-image:url('{{ hero_image_url }}');background-size:cover;background-position:center right;"{% endif %}
>
  <div class="vf-hero-composite__overlay"></div>

  <div class="vf-hero-composite__content">
    <div class="vf-hero-composite__inner">
      {%- if section.settings.eyebrow != blank -%}
        <div class="vf-hero-composite__eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="vf-hero-composite__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="vf-hero-composite__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.button_label_1 != blank or section.settings.button_label_2 != blank -%}
        <div class="vf-hero-composite__buttons">
          {%- if section.settings.button_label_1 != blank -%}
            <a href="{{ section.settings.button_link_1 | default: '#' }}" class="vf-btn vf-btn--gold">
              {{ section.settings.button_label_1 }}
            </a>
          {%- endif -%}
          {%- if section.settings.button_label_2 != blank -%}
            <a href="{{ section.settings.button_link_2 | default: '#' }}" class="vf-btn">
              {{ section.settings.button_label_2 }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.meta_text != blank -%}
        <div class="vf-hero-composite__meta">{{ section.settings.meta_text }}</div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_scroll_indicator -%}
    <div class="vf-hero-composite__scroll">
      <span>Scroll</span>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "VF — Hero Composite",
  "tag": "div",
  "class": "shopify-section--vf-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image",
      "info": "Recommended: 2754×1536 landscape composite (product_hero.svg)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Voxel Forge · Chennai"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sculpted light."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Precision-printed objects, made in editions."
    },
    {
      "type": "header",
      "content": "Primary button (prestige)"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button label",
      "default": "Série II"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button label",
      "default": "Série I"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Meta line"
    },
    {
      "type": "text",
      "id": "meta_text",
      "label": "Meta text",
      "default": "Nº 001 / EST. 2025"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "VF — Hero Composite"
    }
  ]
}
{% endschema %}
