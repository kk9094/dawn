{% comment %}
  VOXEL FORGE — Lucide SVG Router
  Renders exact geometric SVGs mapping to standard Lucide geometry
  Forces stroke-width="1.5" (1pt) and sharp corners.
  
  Usage: {% render 'icon-lucide', icon: 'sun' %}
{% endcomment %}

<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="icon icon-{{ icon }}" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true" focusable="false">
  {% case icon %}
    {% when 'sun' %}
      <circle cx="12" cy="12" r="4"/>
      <path d="M12 2v2"/><path d="M12 20v2"/>
      <path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/>
      <path d="M2 12h2"/><path d="M20 12h2"/>
      <path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
      
    {% when 'moon' %}
      <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>

    {% when 'search' %}
      <circle cx="11" cy="11" r="8"/>
      <path d="m21 21-4.3-4.3"/>

    {% when 'user' %}
      <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
      <circle cx="12" cy="7" r="4"/>

    {% when 'shopping-bag' %}
      <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
      <path d="M3 6h18"/>
      <path d="M16 10a4 4 0 0 1-8 0"/>

    {% when 'arrow-right' %}
      <path d="M5 12h14"/>
      <path d="m12 5 7 7-7 7"/>

    {% else %}
      {% comment %} Fallback box {% endcomment %}
      <rect width="18" height="18" x="3" y="3"/>
  {% endcase %}
</svg>
