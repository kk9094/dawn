{%- comment -%}
  vf-icon — the 19-glyph Voxel Forge icon set

  Required:
    name     — one of:
                 voxel, layers, lamp, home, precision, print,
                 quality, package, delivery, certificate, forge,
                 settings, search, user, cart, menu,
                 atelier, edition, prestige

  Optional:
    size     — pixel size (default 16)
    color    — CSS colour or token reference (default 'currentColor')
    class    — extra class names

  Usage:
    {% render 'vf-icon', name: 'cart', size: 18 %}
    {% render 'vf-icon', name: 'arrow-up-right', size: 14, color: 'var(--vf-teal)' %}

  Rules:
    - All icons stroke-based, hairline width, square caps.
    - currentColor by default so they inherit from parent.
    - viewBox 24x24 for consistency.
{%- endcomment -%}

{%- liquid
  assign size = size | default: 16
  assign color = color | default: 'currentColor'
  assign sw = 1
-%}

<svg
  class="vf-icon vf-icon--{{ name }} {{ class }}"
  width="{{ size }}"
  height="{{ size }}"
  viewBox="0 0 24 24"
  fill="none"
  stroke="{{ color }}"
  stroke-width="{{ sw }}"
  stroke-linecap="square"
  stroke-linejoin="miter"
  aria-hidden="true"
  focusable="false"
>
  {%- case name -%}
    {%- when 'voxel' -%}
      <polygon points="12,2 22,7 22,17 12,22 2,17 2,7"/>
      <line x1="12" y1="2" x2="12" y2="22"/>
      <line x1="2" y1="7" x2="22" y2="17"/>

    {%- when 'layers' -%}
      <polygon points="12,3 21,8 12,13 3,8"/>
      <polyline points="3,12 12,17 21,12"/>
      <polyline points="3,16 12,21 21,16"/>

    {%- when 'lamp' -%}
      <path d="M9 3 H15 L17 9 H7 Z"/>
      <line x1="12" y1="9" x2="12" y2="18"/>
      <line x1="9" y1="21" x2="15" y2="21"/>

    {%- when 'home' -%}
      <polyline points="3,12 12,4 21,12"/>
      <polyline points="5,10 5,21 19,21 19,10"/>

    {%- when 'precision' -%}
      <circle cx="12" cy="12" r="9"/>
      <circle cx="12" cy="12" r="4"/>
      <line x1="12" y1="2" x2="12" y2="22"/>
      <line x1="2" y1="12" x2="22" y2="12"/>

    {%- when 'print' -%}
      <polyline points="6,2 18,2 18,8"/>
      <rect x="3" y="8" width="18" height="9"/>
      <rect x="6" y="14" width="12" height="7"/>

    {%- when 'quality' -%}
      <polygon points="12,2 15,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 9,9"/>

    {%- when 'package' -%}
      <polygon points="12,2 22,7 12,12 2,7"/>
      <polyline points="2,7 2,17 12,22 22,17 22,7"/>
      <line x1="12" y1="12" x2="12" y2="22"/>

    {%- when 'delivery' -%}
      <rect x="2" y="7" width="13" height="10"/>
      <polyline points="15,10 19,10 22,13 22,17 15,17"/>
      <circle cx="6" cy="19" r="2"/>
      <circle cx="18" cy="19" r="2"/>

    {%- when 'certificate' -%}
      <rect x="3" y="3" width="18" height="14"/>
      <polyline points="8,17 8,22 12,19 16,22 16,17"/>
      <line x1="7" y1="8" x2="17" y2="8"/>
      <line x1="7" y1="12" x2="14" y2="12"/>

    {%- when 'forge' -%}
      <polyline points="3,21 21,21"/>
      <path d="M5 21 L7 9 L12 6 L17 9 L19 21"/>
      <line x1="9" y1="21" x2="9" y2="13"/>
      <line x1="15" y1="21" x2="15" y2="13"/>

    {%- when 'settings' -%}
      <circle cx="12" cy="12" r="3"/>
      <path d="M12 2 V5 M12 19 V22 M2 12 H5 M19 12 H22 M5 5 L7 7 M17 17 L19 19 M5 19 L7 17 M17 7 L19 5"/>

    {%- when 'search' -%}
      <circle cx="11" cy="11" r="7"/>
      <line x1="16" y1="16" x2="21" y2="21"/>

    {%- when 'user' -%}
      <circle cx="12" cy="8" r="4"/>
      <path d="M4 21 C4 16 8 14 12 14 C16 14 20 16 20 21"/>

    {%- when 'cart' -%}
      <polyline points="3,4 6,4 8,16 19,16 21,8 7,8"/>
      <circle cx="9" cy="20" r="1.2"/>
      <circle cx="17" cy="20" r="1.2"/>

    {%- when 'menu' -%}
      <line x1="3" y1="7" x2="21" y2="7"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="17" x2="21" y2="17"/>

    {%- when 'atelier' -%}
      <polygon points="12,3 21,9 12,21 3,9"/>
      <line x1="3" y1="9" x2="21" y2="9"/>
      <line x1="12" y1="3" x2="12" y2="21"/>

    {%- when 'edition' -%}
      <rect x="4" y="4" width="16" height="16"/>
      <line x1="4" y1="9" x2="20" y2="9"/>
      <line x1="9" y1="9" x2="9" y2="20"/>
      <line x1="15" y1="9" x2="15" y2="20"/>

    {%- when 'prestige' -%}
      <polygon points="12,3 14,9 21,9 15,13 17,20 12,16 7,20 9,13 3,9 10,9"/>

    {%- when 'arrow-right' -%}
      <line x1="3" y1="12" x2="21" y2="12"/>
      <polyline points="15,6 21,12 15,18"/>

    {%- when 'arrow-up-right' -%}
      <line x1="6" y1="18" x2="18" y2="6"/>
      <polyline points="9,6 18,6 18,15"/>

    {%- else -%}
      {%- comment -%} Unknown icon — render an empty circle so it's visible {%- endcomment -%}
      <circle cx="12" cy="12" r="9"/>
  {%- endcase -%}
</svg>

{% style %}
  .vf-icon {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }
{% endstyle %}
