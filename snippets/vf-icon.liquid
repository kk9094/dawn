{%- comment -%}
  Voxel Forge — Icon System (Lucide v0.400+, MIT)
  Renders inline SVG at 24x24 grid, 1.5px stroke, round caps.

  Params:
    name    (required) — one of the 19 icon names below
    size    (optional) — px integer, default 24
    tier    (optional) — 'serie-2' | 'atelier' | 'prestige' → forces Gold class
    surface (optional) — 'dark' (default) | 'light' → Teal Deep / Gold Dark

  Gold is RESERVED for three names only: atelier · edition · prestige
{%- endcomment -%}

{%- assign vf_size = size | default: 24 -%}
{%- assign vf_surface = surface | default: 'dark' -%}

{%- comment -%} Resolve color class {%- endcomment -%}
{%- assign gold_names = 'atelier,edition,prestige' | split: ',' -%}
{%- assign gold_tiers = 'serie-2,atelier,prestige' | split: ',' -%}
{%- assign is_gold = false -%}
{%- if gold_names contains name -%}
  {%- assign is_gold = true -%}
{%- elsif tier and gold_tiers contains tier -%}
  {%- assign is_gold = true -%}
{%- endif -%}

{%- if is_gold -%}
  {%- if vf_surface == 'light' -%}
    {%- assign vf_class = 'vf-icon vf-icon--gold-dark' -%}
  {%- else -%}
    {%- assign vf_class = 'vf-icon vf-icon--gold' -%}
  {%- endif -%}
{%- else -%}
  {%- if vf_surface == 'light' -%}
    {%- assign vf_class = 'vf-icon vf-icon--teal-deep' -%}
  {%- else -%}
    {%- assign vf_class = 'vf-icon vf-icon--teal' -%}
  {%- endif -%}
{%- endif -%}

<span class="{{ vf_class }}" style="width:{{ vf_size }}px;height:{{ vf_size }}px;" aria-hidden="true">
  {%- case name -%}

    {%- when 'voxel' -%}
      <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" y1="22" x2="12" y2="12"/></svg>

    {%- when 'layers' -%}
      <svg viewBox="0 0 24 24"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>

    {%- when 'lamp' -%}
      <svg viewBox="0 0 24 24"><path d="M8 2h8l4 10H4L8 2z"/><path d="M12 12v6"/><path d="M8 22h8"/></svg>

    {%- when 'home' -%}
      <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>

    {%- when 'precision' -%}
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/></svg>

    {%- when 'print' -%}
      <svg viewBox="0 0 24 24"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>

    {%- when 'quality' -%}
      <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>

    {%- when 'package' -%}
      <svg viewBox="0 0 24 24"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>

    {%- when 'delivery' -%}
      <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>

    {%- when 'certificate' -%}
      <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>

    {%- when 'forge' -%}
      <svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>

    {%- when 'settings' -%}
      <svg viewBox="0 0 24 24"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>

    {%- when 'search' -%}
      <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>

    {%- when 'user' -%}
      <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>

    {%- when 'cart' -%}
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>

    {%- when 'menu' -%}
      <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>

    {%- comment -%} ── GOLD-ONLY ───────────────────────────────── {%- endcomment -%}
    {%- when 'atelier' -%}
      <svg viewBox="0 0 24 24"><polygon points="6 3 18 3 22 9 12 22 2 9 6 3"/><polyline points="2 9 12 9 22 9"/><line x1="12" y1="9" x2="6" y2="3"/><line x1="12" y1="9" x2="18" y2="3"/><line x1="12" y1="9" x2="12" y2="22"/></svg>

    {%- when 'edition' -%}
      <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>

    {%- when 'prestige' -%}
      <svg viewBox="0 0 24 24"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>

  {%- endcase -%}
</span>
