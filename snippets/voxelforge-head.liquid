{%- comment -%}
  VOXEL FORGE — Brand Head Snippet
  Add this to layout/theme.liquid inside the <head> tag
  Paste BEFORE the closing </head> tag
{%- endcomment -%}

{%- comment -%} Google Fonts — Cormorant Garamond + DM Sans {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@200;300;400;500&display=swap"
  rel="stylesheet"
>

{%- comment -%} Brand Architecture CSS Extensions {%- endcomment -%}
{{ 'voxel-forge-core.css' | asset_url | stylesheet_tag }}
{{ 'voxel-components.css' | asset_url | stylesheet_tag }}

{%- comment -%} Brand Motion Observer {%- endcomment -%}
<script src="{{ 'voxel-motion.js' | asset_url }}" defer="defer"></script>

{%- comment -%} Brand meta {%- endcomment -%}
<meta name="theme-color" content="#0A0A0A">
<meta name="msapplication-TileColor" content="#C9A96E">

{%- comment -%} Open Graph brand overrides {%- endcomment -%}
{% if page_title %}
  <meta property="og:title" content="{{ page_title | escape }} — Voxel Forge">
{% else %}
  <meta property="og:title" content="Voxel Forge — Light, Architectured.">
{% endif %}
<meta property="og:description" content="{{ page_description | default: 'Precision cast in shadow and glow. Architectural lighting designed and forged in Chennai.' | escape }}">
<meta property="og:site_name" content="Voxel Forge">
