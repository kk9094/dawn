{%- comment -%}
  VOXEL FORGE — Logo SVG Snippet
  Usage: {% render 'voxelforge-logo' %}
  Add to sections/header.liquid where the logo image is rendered
{%- endcomment -%}

<a href="{{ routes.root_url }}" class="header__heading-link vf-logo-link" title="Voxel Forge — Home">
  <svg
    width="160"
    height="40"
    viewBox="0 0 320 80"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-label="Voxel Forge"
    role="img"
  >
    {%- comment -%} Isometric voxel mark {%- endcomment -%}
    <polygon points="32,8 56,20 56,44 32,56" fill="#1A1A1A" stroke="#C9A96E" stroke-width="0.8"/>
    <polygon points="32,8 8,20 8,44 32,56" fill="#111111" stroke="#C9A96E" stroke-width="0.8"/>
    <polygon points="32,0 56,12 32,24 8,12" fill="#2C2C2C" stroke="#C9A96E" stroke-width="0.8"/>
    <polygon points="44,4 56,10 50,13 38,7" fill="#C9A96E" opacity="0.9"/>
    <polygon points="20,4 32,0 38,3 26,9" fill="#3D7A6B" opacity="0.9"/>
    <line x1="32" y1="24" x2="32" y2="56" stroke="#C9A96E" stroke-width="0.5" opacity="0.5"/>

    {%- comment -%} Wordmark — VOXEL {%- endcomment -%}
    <text
      x="72"
      y="34"
      font-family="'Cormorant Garamond', Georgia, serif"
      font-weight="300"
      font-size="28"
      fill="#E8E2D6"
      letter-spacing="5"
    >VOXEL</text>

    {%- comment -%} Wordmark — FORGE {%- endcomment -%}
    <text
      x="73"
      y="52"
      font-family="'DM Sans', system-ui, sans-serif"
      font-weight="200"
      font-size="10"
      fill="#C9A96E"
      letter-spacing="7"
    >F O R G E</text>
  </svg>
</a>

<style>
  .vf-logo-link {
    display: inline-block;
    transition: opacity 600ms cubic-bezier(0.25, 0, 0, 1);
  }
  .vf-logo-link:hover {
    opacity: 0.75;
  }
</style>
