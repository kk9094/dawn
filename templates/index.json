        "swipe_on_mobile": false,
        "color_scheme": "scheme-1",
        "padding_top": 60,
        "padding_bottom": 0
      }
    },
    "process_strip": {
      "type": "vf-process",
      "blocks": {
        "step_voxel": {
          "type": "step",
          "settings": {
            "icon": "voxel",
            "title": "Mathematical Origin",
            "body": "Every object begins as a parametric equation. Dimensions are computed, not drawn. The geometry is exact before a single layer is laid."
          }
        },
        "step_precision": {
          "type": "step",
          "settings": {
            "icon": "precision",
            "title": "Material Selection",
            "body": "PLA Carbon Fibre. PETG. Resin-infused polymer. The material is chosen for the object's structural reality — not its appearance."
          }
        },
        "step_print": {
          "type": "step",
          "settings": {
            "icon": "print",
            "title": "Layer Calibration",
            "body": "0.08mm layer height. 40% gyroid infill. Each print is calibrated to the specific geometry, not set to a universal default."
          }
        },
        "step_prestige": {
          "type": "step",
          "settings": {
            "icon": "prestige",
            "title": "Surface Resolution",
            "body": "Post-processing at 400-grit. Matte lacquer sealed. The final surface holds the same precision as the internal structure."
          }
        }
      },
      "block_order": ["step_voxel", "step_precision", "step_print", "step_prestige"],
      "settings": {
        "eyebrow": "How we build",
        "title_line1": "From coordinate",
        "title_line2": "object.",
        "description": "Four irreducible stages. No shortcuts. No approximations. The process is the product — every decision made at the resolution of the material itself."
      }
    },
