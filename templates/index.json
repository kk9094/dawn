  "sections": {
    "vf_hero": {
      "type": "vf-hero",
      "settings": {
        "label": "Precision 3D Printed Decor",
        "title_line1": "Where mathematics",
        "title_line2": "becomes",
        "title_line3": "matter.",
        "body_text": "Each object begins as a pure geometric equation. It ends as a weighted, textured, perfectly dimensioned presence in your space. Nothing is approximated. Nothing is reconsidered.",
        "cta_primary_label": "View Collection",
        "cta_primary_link": "shopify://collections/all",
        "cta_secondary_label": "Our Process",
        "cta_secondary_link": ""
      }
    },
    "vf_statement": {
      "type": "vf-statement",
      "settings": {
        "eyebrow": "The philosophy",
        "statement_text": "<p>Luxury is not a surface treatment.<br>It is <em>the refusal to approximate.<\/em><br>Every Voxel Forge object is designed at the resolution of its material.<\/p>",
        "caption": "We build objects that justify space. Not objects that fill it. Each piece is computed, calibrated, and produced at tolerances that conventional manufacturing cannot approach."
      }
    },
    "vf_process": {
      "type": "vf-process",
      "blocks": {
        "step1": {
          "type": "step",
          "settings": {
            "title": "Mathematical Origin",
            "body": "Every object begins as a parametric equation. Dimensions are computed, not drawn. The geometry is exact before a single layer is laid."
          }
        },
        "step2": {
          "type": "step",
          "settings": {
            "title": "Material Selection",
            "body": "PLA Carbon Fibre. PETG. Resin-infused polymer. The material is chosen for the objects structural reality — not its appearance."
          }
        },
        "step3": {
          "type": "step",
          "settings": {
            "title": "Layer Calibration",
            "body": "0.08mm layer height. 40% gyroid infill. Each print is calibrated to the specific geometry, not set to a universal default."
          }
        },
        "step4": {
          "type": "step",
          "settings": {
            "title": "Surface Resolution",
            "body": "Post-processing at 400-grit. Matte lacquer sealed. The final surface holds the same precision as the internal structure."
          }
        }
      },
      "block_order": ["step1", "step2", "step3", "step4"],
      "settings": {
        "eyebrow": "How we build",
        "title_line1": "From coordinate",
        "title_line2": "object.",
        "description": "Four irreducible stages. No shortcuts. No approximations. The process is the product — every decision made at the resolution of the material itself."
      }
    },
