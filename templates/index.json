    "brand_statement": {
      "type": "rich-text",
      "blocks": {
        "statement_heading": {
          "type": "heading",
          "settings": {
            "heading": "A studio in two disciplines.",
            "heading_size": "h2"
          }
        },
        "statement_text": {
          "type": "text",
          "settings": {
            "text": "<p>Tectonic — objects built from horizontal logic. Stratified, gridded, load-bearing in form if not in function. Geometry as architecture.</p><p>Biomorphic — objects built from organic mathematics. Spirals, vortices, the curve of a wave arrested mid-motion. Precision applied to what appears imprecise.</p><p>Both disciplines. One standard. Nothing approximated.</p>"
          }
        }
      },
      "block_order": ["statement_heading", "statement_text"],
      "settings": {
        "desktop_content_position": "center",
        "content_alignment": "center",
        "color_scheme": "scheme-1",
        "full_width": false,
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "form_categories": {
      "type": "multicolumn",
      "blocks": {
        "col_tectonic": {
          "type": "column",
          "settings": {
            "title": "Tectonic",
            "text": "Stratified geometry. Objects built from horizontal logic — structured, architectural, load-bearing in form.",
            "link_label": "Explore Tectonic",
            "link": "shopify://collections/tectonic"
          }
        },
        "col_biomorphic": {
          "type": "column",
          "settings": {
            "title": "Biomorphic",
            "text": "Organic mathematics. Spirals, vortices, the curve of a wave arrested mid-motion. Precision applied to what appears imprecise.",
            "link_label": "Explore Biomorphic",
            "link": "shopify://collections/biomorphic"
          }
        }
      },
      "block_order": ["col_tectonic", "col_biomorphic"],
      "settings": {
        "title": "",
