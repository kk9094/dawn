{%- comment -%}
  VOXEL FORGE — Atelier Commission Page
  Template: templates/page.atelier.liquid
  Atelier is the only page that breaks from dark surface — intentionally.
  Gold is used heavily here to signal exclusivity.
{%- endcomment -%}

<section class="vf-atelier vf-atelier--light">
  <div class="vf-atelier__inner">
    <div class="vf-eyebrow vf-eyebrow--light">
      <span class="vf-eyebrow__text">Commission · 3 per quarter</span>
      <span class="vf-eyebrow__rule" aria-hidden="true"></span>
    </div>
    <h1 class="vf-atelier__h1">An object that has never <em>existed before.</em></h1>
    <p class="vf-atelier__sub">
      The Atelier programme is reserved for clients who require something singular — designed for a specific volume, a specific quality of light, a specific intention. Three commissions per quarter. By application only.
    </p>
    <div class="vf-atelier__mark">
      {% render 'vf-icon', name: 'atelier', size: 48, surface: 'light' %}
    </div>
  </div>
</section>

<section class="vf-atelier vf-atelier--dark vf-atelier--quote">
  <div class="vf-atelier__inner vf-atelier__inner--narrow">
    {% render 'vf-quote',
       text: 'The brief is never a sketch. It is a description of the light at a particular hour, a measurement of the room, a reading of the materials already present.',
       attribution: 'Voxel Forge — Studio Notes' %}
  </div>
</section>

<section class="vf-atelier vf-atelier--light vf-atelier--process">
  <div class="vf-atelier__inner">
    <div class="vf-eyebrow vf-eyebrow--light">
      <span class="vf-eyebrow__text">The process</span>
      <span class="vf-eyebrow__rule" aria-hidden="true"></span>
    </div>
    <h2 class="vf-atelier__h2">Four conversations, eight to fourteen weeks.</h2>

    <div class="vf-atelier__steps">
      <div class="vf-atelier__step">
        <div class="vf-atelier__step-icon">{% render 'vf-icon', name: 'atelier', size: 28, surface: 'light' %}</div>
        <div class="vf-atelier__step-num">01</div>
        <div class="vf-atelier__step-title">Application</div>
        <p class="vf-atelier__step-body">A short brief describing the room, the intent, and the material context. Reviewed within five days.</p>
      </div>
      <div class="vf-atelier__step">
        <div class="vf-atelier__step-icon">{% render 'vf-icon', name: 'precision', size: 28, surface: 'light' %}</div>
        <div class="vf-atelier__step-num">02</div>
        <div class="vf-atelier__step-title">Specification</div>
        <p class="vf-atelier__step-body">Geometry, material, and light distribution defined in collaboration with you and your architect.</p>
      </div>
      <div class="vf-atelier__step">
        <div class="vf-atelier__step-icon">{% render 'vf-icon', name: 'forge', size: 28, surface: 'light' %}</div>
        <div class="vf-atelier__step-num">03</div>
        <div class="vf-atelier__step-title">Forge</div>
        <p class="vf-atelier__step-body">Calibration, print, finish. A single object — built to the specification, photographed at every stage.</p>
      </div>
      <div class="vf-atelier__step">
        <div class="vf-atelier__step-icon">{% render 'vf-icon', name: 'prestige', size: 28, surface: 'light' %}</div>
        <div class="vf-atelier__step-num">04</div>
        <div class="vf-atelier__step-title">Delivery</div>
        <p class="vf-atelier__step-body">Hand-finished, sealed, delivered with a signed certificate of origin and care record.</p>
      </div>
    </div>
  </div>
</section>

<section class="vf-atelier vf-atelier--dark" id="apply">
  <div class="vf-atelier__inner vf-atelier__inner--narrow">
    <div class="vf-eyebrow vf-eyebrow--dark">
      <span class="vf-eyebrow__text">Begin a conversation</span>
      <span class="vf-eyebrow__rule" aria-hidden="true"></span>
    </div>
    <h2 class="vf-atelier__h2 vf-atelier__h2--dark">Submit a brief.</h2>
    <p class="vf-atelier__sub vf-atelier__sub--dark">
      Atelier enquiries are reviewed personally. Expect a reply within 48 hours.
    </p>

    {% form 'contact', class: 'vf-atelier__form' %}
      {% if form.posted_successfully? %}
        <p class="vf-form-success">Your enquiry has been received. We will be in contact within 48 hours.</p>
      {% else %}
        {% if form.errors %}
          <p class="vf-form-success" style="color:var(--vf-coral);border-color:var(--vf-coral);">
            {{ form.errors | default_errors }}
          </p>
        {% endif %}

        <fieldset class="vf-form-fieldset">
          <legend>Project</legend>
          <div class="vf-field">
            <label for="atelier-space">Describe your space</label>
            <textarea id="atelier-space" name="contact[body]" rows="6" placeholder="Room dimensions, existing materials, the quality of light you are working with..." required></textarea>
          </div>
          <div class="vf-field">
            <label for="atelier-budget">Approximate budget (₹)</label>
            <select id="atelier-budget" name="contact[budget]">
              <option value="">Select a range</option>
              <option value="50000-150000">₹50,000 — ₹1,50,000</option>
              <option value="150000-500000">₹1,50,000 — ₹5,00,000</option>
              <option value="500000+">₹5,00,000+</option>
            </select>
          </div>
          <div class="vf-field">
            <label for="atelier-timeline">Desired timeline</label>
            <input type="text" id="atelier-timeline" name="contact[timeline]" placeholder="e.g. installation by Q3 2026">
          </div>
        </fieldset>

        <fieldset class="vf-form-fieldset">
          <legend>You</legend>
          <div class="vf-field">
            <label for="atelier-name">Full name</label>
            <input type="text" id="atelier-name" name="contact[name]" autocomplete="name" required>
          </div>
          <div class="vf-field">
            <label for="atelier-email">Email address</label>
            <input type="email" id="atelier-email" name="contact[email]" autocomplete="email" required>
          </div>
          <div class="vf-field">
            <label for="atelier-architect">Architect or designer (optional)</label>
            <input type="text" id="atelier-architect" name="contact[architect]" autocomplete="off">
          </div>
        </fieldset>

        <button type="submit" class="vf-btn vf-btn--atelier vf-atelier__submit">Submit enquiry</button>
      {% endif %}
    {% endform %}
  </div>
</section>

<section class="vf-atelier vf-atelier--dark vf-atelier--closing">
  <div class="vf-atelier__inner vf-atelier__inner--narrow vf-atelier__closing">
    <p class="vf-atelier__closing-line">By application only.</p>
    <div class="vf-atelier__closing-mark">{% render 'vf-icon', name: 'forge', size: 20 %}</div>
  </div>
</section>

<style>
  .vf-atelier { padding: 8rem 3rem; }
  .vf-atelier--light { background: var(--vf-warm-white); color: var(--vf-obsidian); }
  .vf-atelier--dark  { background: var(--vf-obsidian);   color: var(--vf-bone); }
  .vf-atelier__inner { max-width: 1320px; margin: 0 auto; }
  .vf-atelier__inner--narrow { max-width: 720px; }

  .vf-atelier__h1 {
    font-family: var(--vf-serif);
    font-weight: 300;
    font-size: clamp(3rem, 5.5vw, 5rem);
    line-height: 1.05;
    letter-spacing: 0.005em;
    color: var(--vf-teal-deep);
    margin: 1.5rem 0 1.5rem;
    max-width: 900px;
  }
  .vf-atelier__h1 em { font-style: italic; color: var(--vf-gold-dark); }

  .vf-atelier__h2 {
    font-family: var(--vf-serif);
    font-weight: 300;
    font-size: clamp(2rem, 3.4vw, 2.8rem);
    line-height: 1.15;
    color: var(--vf-teal-deep);
    margin: 1.5rem 0 3rem;
  }
  .vf-atelier__h2--dark { color: var(--vf-bone); }

  .vf-atelier__sub {
    font-family: var(--vf-sans);
    font-size: 0.95rem;
    line-height: 1.85;
    color: rgba(10,10,10,0.62);
    max-width: 560px;
  }
  .vf-atelier__sub--dark { color: rgba(232,226,214,0.55); }

  .vf-atelier__mark { margin-top: 3rem; }

  .vf-atelier--quote { padding: 6rem 3rem; }

  .vf-atelier__steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-top: 2.5rem;
  }
  .vf-atelier__step {
    padding: 2.5rem 2rem;
    border-left: 0.5px solid rgba(10,10,10,0.12);
  }
  .vf-atelier__step:first-child { border-left: none; padding-left: 0; }
  .vf-atelier__step-icon { margin-bottom: 1.5rem; }
  .vf-atelier__step-num {
    font-family: var(--vf-mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    color: var(--vf-gold-dark);
    margin-bottom: 0.85rem;
  }
  .vf-atelier__step-title {
    font-family: var(--vf-serif);
    font-size: 1.35rem;
    color: var(--vf-obsidian);
    margin-bottom: 0.85rem;
  }
  .vf-atelier__step-body {
    font-family: var(--vf-sans);
    font-size: 0.78rem;
    line-height: 1.85;
    color: rgba(10,10,10,0.55);
  }

  .vf-atelier__form { margin-top: 2.5rem; }
  .vf-atelier__submit { width: 100%; margin-top: 1rem; }

  .vf-atelier__closing { text-align: center; }
  .vf-atelier__closing-line {
    font-family: var(--vf-serif);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--vf-gold);
    margin-bottom: 1.5rem;
  }
  .vf-atelier__closing-mark { display: inline-flex; }

  @media screen and (max-width: 989px) {
    .vf-atelier { padding: 5rem 1.5rem; }
    .vf-atelier__steps { grid-template-columns: 1fr 1fr; }
    .vf-atelier__step { border-left: none; border-top: 0.5px solid rgba(10,10,10,0.12); padding: 2rem 0; }
    .vf-atelier__step:nth-child(1),
    .vf-atelier__step:nth-child(2) { border-top: none; padding-top: 0; }
  }
</style>
