{%- comment -%}
  VOXEL FORGE — Atelier Commission Page
  Template: templates/page.atelier.liquid
  Go to Online Store → Pages → Atelier → Template → select "page.atelier"
{%- endcomment -%}

<div class="vf-atelier-page">

  {%- comment -%} Decorative rule {%- endcomment -%}
  <div class="vf-atelier-rule"></div>

  <div class="vf-atelier-header">
    <p class="vf-section-label">Bespoke · Commission</p>
    <h1 class="vf-atelier-title">Atelier</h1>
    <p class="vf-atelier-sub">No catalogue. Each piece designed from first principles for a specific space.</p>
  </div>

  <div class="vf-atelier-body">
    <div class="vf-atelier-text">
      <p>The Atelier programme is for clients who require something that does not yet exist. Working directly with Voxel Forge, each commission begins with a spatial brief — a photograph, a drawing, a description of light at a specific time of day.</p>
      <p>Material, geometry, and light distribution are specified in collaboration with you and, where applicable, your architect or interior designer.</p>
      <p>Commissions are accepted on a rolling basis. Lead time is typically 8 — 14 weeks from brief to delivery.</p>
    </div>

    <div class="vf-atelier-form">
      <p class="vf-form-label">Begin a conversation</p>
      {% form 'contact', class: 'vf-contact-form' %}
        {% if form.posted_successfully? %}
          <p class="vf-form-success">Your enquiry has been received. We will be in contact within 48 hours.</p>
        {% else %}
          <div class="vf-field">
            <label for="atelier-name">Full name</label>
            <input type="text" id="atelier-name" name="contact[name]" autocomplete="name" required>
          </div>

          <div class="vf-field">
            <label for="atelier-email">Email address</label>
            <input type="email" id="atelier-email" name="contact[email]" autocomplete="email" required>
          </div>

          <div class="vf-field">
            <label for="atelier-space">Describe your space</label>
            <textarea id="atelier-space" name="contact[body]" rows="6" placeholder="Room dimensions, existing materials, the quality of light you are working with..."></textarea>
          </div>

          <div class="vf-field">
            <label for="atelier-budget">Approximate budget (₹)</label>
            <select id="atelier-budget" name="contact[budget]">
              <option value="">Select a range</option>
              <option value="50000-150000">₹50,000 — ₹1,50,000</option>
              <option value="150000-500000">₹1,50,000 — ₹5,00,000</option>
              <option value="500000+">₹5,00,000+</option>
            </select>
          </div>

          <button type="submit" class="vf-atelier-submit">Submit enquiry</button>
        {% endif %}
      {% endform %}
    </div>
  </div>

</div>

<style>
  .vf-atelier-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 80px 40px;
  }

  .vf-atelier-rule {
    width: 32px;
    height: 1px;
    background-color: #3D7A6B;
    margin-bottom: 40px;
  }

  .vf-atelier-header {
    margin-bottom: 64px;
  }

  .vf-section-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: #C9A96E;
    margin-bottom: 16px;
  }

  .vf-atelier-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(48px, 6vw, 80px);
    letter-spacing: 0.04em;
    color: #E8E2D6;
    line-height: 1;
    margin-bottom: 16px;
  }

  .vf-atelier-sub {
    font-family: 'DM Sans', sans-serif;
    font-weight: 200;
    font-size: 14px;
    letter-spacing: 0.08em;
    color: #9A9585;
    max-width: 480px;
    line-height: 1.8;
  }

  .vf-atelier-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .vf-atelier-text p {
    font-family: 'DM Sans', sans-serif;
    font-weight: 200;
    font-size: 14px;
    line-height: 1.9;
    color: #9A9585;
    margin-bottom: 20px;
    letter-spacing: 0.04em;
  }

  .vf-form-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #C9A96E;
    margin-bottom: 28px;
  }

  .vf-field {
    margin-bottom: 20px;
  }

  .vf-field label {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #4A4A4A;
    margin-bottom: 8px;
  }

  .vf-field input,
  .vf-field textarea,
  .vf-field select {
    width: 100%;
    background-color: #1A1A1A;
    border: 0.5px solid #2C2C2C;
    border-radius: 0;
    color: #E8E2D6;
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 13px;
    letter-spacing: 0.06em;
    padding: 12px 14px;
    transition: border-color 600ms cubic-bezier(0.25,0,0,1);
    outline: none;
  }

  .vf-field input:focus,
  .vf-field textarea:focus,
  .vf-field select:focus {
    border-color: #C9A96E;
  }

  .vf-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .vf-atelier-submit {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #C9A96E;
    background: transparent;
    border: 1px solid #C9A96E;
    padding: 14px 28px;
    cursor: pointer;
    width: 100%;
    margin-top: 8px;
    transition: all 600ms cubic-bezier(0.25,0,0,1);
  }

  .vf-atelier-submit:hover {
    background-color: #C9A96E;
    color: #0A0A0A;
  }

  .vf-form-success {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 18px;
    color: #3D7A6B;
    font-style: italic;
    padding: 24px;
    border: 0.5px solid #3D7A6B;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .vf-atelier-page { padding: 48px 24px; }
    .vf-atelier-body { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
