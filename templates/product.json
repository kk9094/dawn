{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "form_category": {
          "type": "text",
          "settings": {
            "text": "{{ product.metafields.voxel.form_category | default: product.type }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        },
        "description": {
          "type": "description"
        },
        "tab_care": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Care",
            "icon": "heart",
            "content": "",
            "page": ""
          }
        },
        "tab_shipping": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping & Returns",
            "icon": "truck",
            "content": "",
            "page": ""
          }
        },
        "tab_commission": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Commission",
            "icon": "chat_bubble",
            "content": "",
            "page": ""
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "form_category",
        "title",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "description",
        "tab_care",
        "tab_shipping",
        "tab_commission",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 60,
        "padding_bottom": 0
      }
    },
    "product_specs": {
      "type": "vf-product-specs",
      "settings": {
        "eyebrow": "Specifications",
        "show_metafields": true
      }
    },
    "related_products": {
      "type": "related-products",
      "settings": {
        "heading": "Related objects",
        "heading_size": "h2",
        "columns_desktop": 3,
        "color_scheme": "scheme-1",
        "image_ratio": "portrait",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 60,
        "padding_bottom": 60
      }
    }
  },
  "order": [
    "main",
    "product_specs",
    "related_products"
  ]
}
